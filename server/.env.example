# ============ Node ============
NODE_ID=node-1
NAMESPACE=production
NODE_ENV=development

# ============ Database ============
# PostgreSQL 连接 (用于 TypeORM)
DATABASE_URL=postgresql://postgres:123456@localhost:5432/directus

# 连接池配置
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_TOTAL_LIMIT=100
DB_POOL_IDLE_TIMEOUT=1800000

# ============ Redis ============
# Moleculer transporter
TRANSPORTER=redis://localhost:6379

# Moleculer cacher
CACHER=redis://localhost:6379

# Redis 连接
REDIS_HOST=localhost
REDIS_PORT=6379

# ============ JWT ============
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ============ API ============
API_PORT=3000
API_HOST=0.0.0.0

# ============ CORS ============
CORS_ORIGIN=*

# ============ AI (Optional) ============
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1

# ============ Log ============
LOG_LEVEL=info
